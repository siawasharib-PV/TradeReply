# TradeReply Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# TWILIO CONFIGURATION
# ============================================
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+61468155994

# ============================================
# GEMINI API CONFIGURATION
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
TRADEREPLY_MODEL=gemini-2.0-flash

# ============================================
# DATABASE CONFIGURATION
# ============================================
TRADEREPLY_DB_PATH=data/tradereply.db

# ============================================
# GOOGLE BUSINESS API (Phase 2)
# ============================================
GOOGLE_CREDENTIALS_PATH=/path/to/google-credentials.json
GOOGLE_BUSINESS_ACCOUNT_ID=your_account_id_here

# ============================================
# FASTAPI CONFIGURATION
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=development

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=tradereply.log

# ============================================
# FEATURE FLAGS
# ============================================
DRY_RUN_SMS=true         # true = log SMS, false = send real SMS
DRY_RUN_AI=false         # true = mock AI, false = use real Gemini
