# TradeReply Production Environment Configuration
# Copy to a secure production .env and fill in real values

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=production
DEBUG=false

# ============================================
# TWILIO CONFIGURATION (REQUIRED)
# ============================================
TWILIO_ACCOUNT_SID=your_real_account_sid
TWILIO_AUTH_TOKEN=your_real_auth_token
TWILIO_FROM_NUMBER=+61468155994

# ============================================
# GEMINI / AI CONFIGURATION (REQUIRED)
# ============================================
GEMINI_API_KEY=your_real_gemini_api_key
TRADEREPLY_MODEL=gemini-2.0-flash

# ============================================
# DATABASE CONFIGURATION
# ============================================
TRADEREPLY_DB_PATH=data/tradereply.db

# ============================================
# GOOGLE BUSINESS CONFIGURATION (REQUIRED FOR LIVE POSTING)
# ============================================
GOOGLE_CREDENTIALS_PATH=/absolute/path/to/google-credentials.json
GOOGLE_BUSINESS_ACCOUNT_ID=your_live_google_business_account_id

# ============================================
# FASTAPI CONFIGURATION
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=tradereply.log

# ============================================
# FEATURE FLAGS (MUST BE FALSE IN PRODUCTION)
# ============================================
DRY_RUN_SMS=false
DRY_RUN_AI=false
